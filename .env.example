# Copy to .env and adjust. All config is via env vars (SPEC §5).

# --- App ---
APP_NAME=Portfolio Manager API
DEBUG=false

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Auth (JWT) ---
# CHANGE THIS in any real deployment.
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Background jobs (seconds) ---
PRICE_REFRESH_INTERVAL=900
SNAPSHOT_INTERVAL=3600

# --- Analytics ---
# Base reporting currency (everything is converted to it for aggregation).
BASE_CURRENCY=RUB
# Risk-free rate for Sharpe/Sortino/CAPM (fraction, e.g. 0.07 == 7%).
RISK_FREE_RATE=0.07
TRADING_DAYS=252
# Benchmark asset symbol the dashboard compares against.
BENCHMARK_SYMBOL=IMOEX

# --- Pricing providers ---
PRICE_HTTP_TIMEOUT=8.0
MOEX_BASE_URL=https://iss.moex.com/iss
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
YAHOO_BASE_URL=https://query1.finance.yahoo.com
# Days of history backfilled when first pricing an asset.
HISTORY_DAYS=365
