# Copy to .env and adjust. All config is via env vars (SPEC §5).

# --- App ---
APP_NAME=Portfolio Manager API
DEBUG=false

# --- CORS ---
# Comma-separated list of allowed browser origins. Backend and frontend
# live on different subdomains in production, so the browser treats every
# call as cross-origin — without this the SPA cannot talk to the API.
#
# Dev:   CORS_ORIGINS=http://localhost:3000
# Prod:  CORS_ORIGINS=https://front-kurs.fiornrrn.ru
CORS_ORIGINS=http://localhost:3000

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Auth (JWT) ---
# CHANGE THIS in any real deployment.
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Background jobs (seconds) ---
PRICE_REFRESH_INTERVAL=900
SNAPSHOT_INTERVAL=3600
